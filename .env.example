# ============================================================
# MedFlow Frontend — .env.local (local development)
# Copy this file to .env.local and adjust values.
# Vite only exposes VITE_* variables to the browser bundle.
# ============================================================

# Backend API base URL — change to your deployed URL in staging/production
VITE_API_BASE_URL=http://localhost:5001/api

VITE_APP_NAME=MedFlow
VITE_APP_ENV=development
